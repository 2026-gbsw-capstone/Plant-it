<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <title>Plant-it Admin - Guide Form</title>
    <style>
        body { margin: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; background: #f6f3ed; color: #2f2d2a; }
        header { padding: 24px 32px; background: #1f1f1f; color: white; display: flex; justify-content: space-between; align-items: center; }
        main { max-width: 860px; margin: 0 auto; padding: 32px; }
        a { color: #167744; text-decoration: none; font-weight: 700; }
        form { background: white; padding: 24px; border-radius: 10px; display: grid; gap: 18px; }
        label { display: grid; gap: 8px; font-weight: 700; }
        input, textarea { width: 100%; box-sizing: border-box; padding: 12px; border: 1px solid #d8d1c7; border-radius: 8px; font: inherit; }
        textarea { min-height: 92px; resize: vertical; }
        .actions { display: flex; gap: 10px; align-items: center; }
        button { border: 0; padding: 11px 16px; border-radius: 8px; background: #28a362; color: white; font-weight: 800; cursor: pointer; }
        .logout { padding: 8px 12px; background: #444; }
        .secondary { color: #666; }
        .errors { padding: 12px 14px; background: #fff2f2; border: 1px solid #ffd2d2; border-radius: 8px; color: #9b2525; }
    </style>
</head>
<body>
<header>
    <strong>Plant-it DB Admin</strong>
    <form method="post" action="/admin/logout"><button class="logout" type="submit">로그아웃</button></form>
</header>
<main>
    <p><a href="/admin/guides">목록으로</a></p>
    <h1>{{#guideId}}식물도감 수정{{/guideId}}{{^guideId}}식물도감 추가{{/guideId}}</h1>

    {{#hasErrors}}
        <div class="errors">필수 값을 확인해주세요.</div>
    {{/hasErrors}}

    <form method="post" action="{{action}}">
        {{#form}}
            <label>종 이름
                <input name="speciesName" value="{{speciesName}}" maxlength="100" placeholder="예: 마밀라리아 (Mammillaria gracilis)" required>
            </label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <label>크기
                    <input name="size" value="{{size}}" placeholder="예: 5 ~ 20cm">
                </label>
                <label>수명
                    <input name="lifespan" value="{{lifespan}}" placeholder="예: 10 ~ 30년">
                </label>
            </div>
            <label>이미지
                <div style="display: flex; gap: 12px; align-items: flex-start;">
                    <img id="imagePreview" src="{{#imageUrl}}{{imageUrl}}{{/imageUrl}}{{^imageUrl}}https://via.placeholder.com/150?text=No+Image{{/imageUrl}}"
                         style="width: 150px; height: 150px; object-fit: cover; border-radius: 8px; border: 1px solid #d8d1c7;">
                    <div style="display: grid; gap: 8px; flex: 1;">
                        <div style="display: flex; gap: 8px;">
                            <input type="file" id="imageFile" accept="image/*" style="width: auto;">
                            <button type="button" id="uploadBtn" style="background: #444; font-size: 13px; padding: 6px 10px; width: fit-content;">이미지 업로드</button>
                        </div>
                        <input type="text" name="imageUrl" id="imageUrl" value="{{imageUrl}}" placeholder="이미지 URL (업로드 시 자동 채워짐)">
                        <small id="uploadStatus" style="color: #666;"></small>
                    </div>
                </div>
            </label>
            <label>특징 (흥미로운 점 중심)
                <textarea name="description" placeholder="식물의 유래, 외형적 특징, 장단점 등을 이야기하듯 적어주세요.">{{description}}</textarea>
            </label>

            <h3 style="margin-top: 24px; border-bottom: 2px solid #ede8df; padding-bottom: 8px;">관리 방법 (읽고 따라하기 쉽게)</h3>
            <label>물주기
                <textarea name="watering" placeholder="계절별 물주기 횟수와 양을 상세히 적어주세요." required>{{watering}}</textarea>
            </label>
            <label>햇빛
                <textarea name="sunlight" placeholder="필요한 일조량과 추천 위치를 적어주세요." required>{{sunlight}}</textarea>
            </label>
            <label>온도 & 습도
                <textarea name="temperature" placeholder="적정 온도와 습도, 겨울철 주의사항 등을 적어주세요.">{{temperature}}</textarea>
            </label>
            <label>비료
                <textarea name="fertilizer" placeholder="비료 종류와 주기, 양을 적어주세요.">{{fertilizer}}</textarea>
            </label>
            <label>기타 (분갈이, 주의사항 등)
                <textarea name="humidity" placeholder="분갈이 주기나 독성 정보, 과습 시 대처법 등을 적어주세요.">{{humidity}}</textarea>
            </label>
        {{/form}}
        <div class="actions">
            <button type="submit">저장</button>
            <a class="secondary" href="/admin/guides">취소</a>
        </div>
    </form>
    <script>
        document.getElementById('uploadBtn').addEventListener('click', async () => {
            const fileInput = document.getElementById('imageFile');
            const status = document.getElementById('uploadStatus');
            const preview = document.getElementById('imagePreview');
            const urlInput = document.getElementById('imageUrl');

            if (!fileInput.files || fileInput.files.length === 0) {
                alert('파일을 선택해주세요.');
                return;
            }

            const formData = new FormData();
            formData.append('file', fileInput.files[0]);
            formData.append('type', 'guide');

            status.textContent = '업로드 중...';
            try {
                const response = await fetch('/api/v1/uploads/images', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                if (result.success) {
                    const newUrl = result.data.imageUrl;
                    urlInput.value = newUrl;
                    preview.src = newUrl;
                    status.textContent = '업로드 완료!';
                } else {
                    status.textContent = '업로드 실패: ' + result.message;
                }
            } catch (error) {
                status.textContent = '업로드 오류 발생';
                console.error(error);
            }
        });
    </script>
</main>
</body>
</html>
