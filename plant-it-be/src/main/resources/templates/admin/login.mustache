<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <title>Plant-it Admin Login</title>
    <style>
        body { margin: 0; min-height: 100vh; display: grid; place-items: center; font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; background: #1f1f1f; color: #2f2d2a; }
        main { width: min(420px, calc(100vw - 40px)); background: #f6f3ed; border-radius: 12px; padding: 28px; box-sizing: border-box; }
        h1 { margin-top: 0; }
        form { display: grid; gap: 14px; }
        label { display: grid; gap: 8px; font-weight: 800; }
        input { padding: 12px; border: 1px solid #d8d1c7; border-radius: 8px; font: inherit; }
        button { border: 0; padding: 12px 16px; border-radius: 8px; background: #28a362; color: white; font-weight: 900; cursor: pointer; }
        .error { margin-bottom: 14px; padding: 12px; border-radius: 8px; background: #fff2f2; color: #9b2525; border: 1px solid #ffd2d2; }
    </style>
</head>
<body>
<main>
    <h1>Admin Login</h1>
    {{#error}}
        <div class="error">아이디 또는 비밀번호가 올바르지 않습니다.</div>
    {{/error}}
    <form method="post" action="/admin/login">
        <label>ID
            <input name="username" autocomplete="username" required>
        </label>
        <label>Password
            <input type="password" name="password" autocomplete="current-password" required>
        </label>
        <button type="submit">로그인</button>
    </form>
</main>
</body>
</html>
